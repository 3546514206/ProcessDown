# ===================================================
#             ProcessDown 环境变量配置
# ===================================================
# 注意：此文件包含敏感信息，绝对不能将真实信息提交到版本控制！
# ===================================================

# ----------------------------------------
# LLM API 配置（必需）
# ----------------------------------------

# API 基础地址（完整URL，包含协议和路径）
LLM_API_BASE_URL=https://api.openai.com/v1

# API 密钥
LLM_API_KEY=your-api-key-here

# 模型名称
LLM_MODEL=gpt-4o

# ----------------------------------------
# 服务器配置（可选，有默认值）
# ----------------------------------------

# 服务器端口（默认：3000）
SERVER_PORT=3000

# 请求超时时间，单位秒（默认：120）
REQUEST_TIMEOUT=120

# ----------------------------------------
# 安全配置（可选）
# ----------------------------------------

# 允许的 CORS 域名（多个用逗号分隔，不含通配符）
ALLOWED_ORIGINS=

# API 认证密钥（用于保护 API 接口）
API_AUTH_KEY=

# 日志级别：debug, info, warn, error（默认：info）
LOG_LEVEL=info

# Node 环境：development, production（默认：production）
NODE_ENV=production